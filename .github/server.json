{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.zseta/progi",
  "title": "Progi",
  "description": "MCP-native workflow engine: teach agents your processes once, they execute them consistently.",
  "websiteUrl": "https://progi.dev",
  "icons": [
    {
      "src": "https://progi.dev/images/progi-p-icon.png",
      "mimeType": "image/png",
      "sizes": ["256x256"]
    }
  ],
  "repository": {
    "url": "https://github.com/zseta/progi",
    "source": "github"
  },
  "version": "0.3.2-registry.1",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "progi",
      "version": "0.3.2",
      "runtimeHint": "uvx",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "PROGI_DB_PATH",
          "description": "Custom path for the Progi SQLite database file",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
